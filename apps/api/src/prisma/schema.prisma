generator client {
  provider               = "prisma-client"
  engineType             = "client"
  output                 = "./generated"
  runtime                = "nodejs"
  moduleFormat           = "esm"
  generatedFileExtension = "ts"
  importFileExtension    = "ts"
  previewFeatures        = ["typedSql"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String   @id @default(dbgenerated("snowflake()"))
  name       String
  username   String   @unique
  email      String   @unique
  avatar     String?
  banner     String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  sessions Session[]
  account  Account?
  // posts    Post[]
  // comments Comments[]

  @@map("user")
}

model Session {
  id         String   @id @default(dbgenerated("snowflake()"))
  expires_at DateTime
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  user_id    String

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("session")
}

model Account {
  id             String   @id @default(dbgenerated("snowflake()"))
  user_id        String   @unique
  email_verified Boolean  @default(false)
  password       String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("account")
}

